# Local-dev Worker vars. These are Cloudflare's PUBLISHED dummy Turnstile
# credentials (always pass) and a fake Resend key — no real secrets here;
# real values live in Doppler and are pushed with `wrangler secret put`.
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
RESEND_API_KEY=re_local_dev_fake_key
DELETE_LINK_SECRET=local-dev-delete-secret
