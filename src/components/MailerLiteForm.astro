---
/*
  MailerLite Season 2 registration form (custom HTML embed).

  VENDORED FROM design-reference/mailerlite-embed.html. Per the PRD the form
  action and every name="fields[...]" attribute are kept EXACTLY so MailerLite's
  field mapping, double opt-in, bot protection, and group automation keep
  working. We restyle only: the pink theme is recolored to the LOTL brand and
  the fonts swapped to Newsreader/Geist. The MailerLite-hosted header image is
  removed (page provides its own heading) so there is no MailerLite badge.

  Radio/option `value=` strings are MailerLite DATA (some include em dashes) and
  are intentionally left verbatim; they are not site copy, so the no-em-dash
  brand rule does not apply to them.
*/
---

<style is:global>
  /* Brand-restyled MailerLite embed (recolored from the exported pink theme). */
  #mlb2-41908249.ml-form-embedContainer { box-sizing: border-box; display: table; margin: 0 auto; position: static; width: 100% !important; }
  #mlb2-41908249.ml-form-embedContainer h4,
  #mlb2-41908249.ml-form-embedContainer p,
  #mlb2-41908249.ml-form-embedContainer span,
  #mlb2-41908249.ml-form-embedContainer button { text-transform: none !important; letter-spacing: normal !important; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper { background-color: #FBF6EC; border-width: 1px; border-color: #DE809F; border-radius: 24px; border-style: solid; box-sizing: border-box; display: inline-block !important; margin: 0; padding: 8px; position: relative; box-shadow: 0 24px 60px -36px rgba(26,74,51,0.55); }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper.embedForm { max-width: 580px; width: 100%; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-align-center { text-align: center; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-successBody { padding: 24px 24px 4px 24px; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedContent { text-align: left; margin: 0 0 20px 0; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedContent h4,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-successBody .ml-form-successContent h4 { color: #1A4A33; font-family: 'Newsreader', serif; font-size: 30px; font-weight: 400; margin: 0 0 10px 0; text-align: center; word-break: break-word; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedContent p,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-successBody .ml-form-successContent p { color: #1C1C22; font-family: 'Geist', sans-serif; font-size: 16px; font-weight: 300; line-height: 22px; margin: 0 0 10px 0; text-align: left; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-block-form .ml-field-group { text-align: left !important; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-block-form .ml-field-group label { margin-bottom: 5px; color: #1A4A33; font-size: 15px; font-family: 'Geist', sans-serif; font-weight: 500; font-style: normal; text-decoration: none; display: inline-block; line-height: 22px; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody form { margin: 0; width: 100%; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-formContent { margin: 0 0 20px 0; width: 100%; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow { margin: 0 0 14px 0; width: 100%; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow.ml-last-item { margin: 0; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow input,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow textarea { background-color: #ffffff !important; color: #1C1C22 !important; border-color: rgba(26,74,51,0.25); border-radius: 10px !important; border-style: solid !important; border-width: 1px !important; font-family: 'Geist', sans-serif; font-size: 16px !important; height: auto; line-height: 21px !important; margin: 0; padding: 11px 12px !important; width: 100% !important; box-sizing: border-box !important; max-width: 100% !important; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow input:focus,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow textarea:focus,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow .custom-select:focus { outline: none; border-color: #DE809F !important; box-shadow: 0 0 0 3px rgba(222,128,159,0.18); }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow .custom-control-label::before,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-checkboxRow .label-description::before { border-color: rgba(26,74,51,0.35) !important; background-color: #ffffff !important; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow .custom-radio .custom-control-input:checked~.custom-control-label::before,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow .custom-checkbox .custom-control-input:checked~.custom-control-label::before,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-checkboxRow input[type=checkbox]:checked~.label-description::before { border-color: #1A4A33 !important; background-color: #DE809F !important; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow .custom-select { background-color: #ffffff !important; color: #1C1C22 !important; border-color: rgba(26,74,51,0.25); border-radius: 10px !important; border-style: solid !important; border-width: 1px !important; font-family: 'Geist', sans-serif; font-size: 16px !important; line-height: 20px !important; margin: 0; padding: 11px 28px 11px 12px !important; width: 100% !important; box-sizing: border-box !important; max-width: 100% !important; height: auto; display: inline-block; vertical-align: middle; background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6"><path d="M1 1l4 4 4-4" fill="none" stroke="%231A4A33" stroke-width="1.5"/></svg>') no-repeat right .85rem center; -webkit-appearance: none; -moz-appearance: none; appearance: none; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow .custom-radio .custom-control-label,
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-fieldRow .custom-checkbox .custom-control-label { color: #1C1C22; font-size: 15px !important; font-family: 'Geist', sans-serif; line-height: 24px; margin-bottom: 0; position: relative; vertical-align: top; font-style: normal; font-weight: 400; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedSubmit { margin: 4px 0 20px 0; float: left; width: 100%; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedSubmit button { background-image: linear-gradient(120deg, #1A4A33, #DE809F) !important; background-color: #DE809F !important; border: none !important; border-radius: 9999px !important; box-shadow: 0 12px 30px -14px rgba(26,74,51,0.6) !important; color: #FBF6EC !important; cursor: pointer; font-family: 'Geist', sans-serif !important; font-size: 15px !important; font-weight: 500 !important; line-height: 21px !important; height: auto; padding: 13px !important; width: 100% !important; box-sizing: border-box !important; transition: transform .25s ease, letter-spacing .25s ease; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedSubmit button.loading { display: none; }
  #mlb2-41908249.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedSubmit button:hover { transform: translateY(-2px); letter-spacing: 0.04em; }
  .ml-error input, .ml-error textarea, .ml-error select { border-color: #c0392b !important; }
  .ml-error .label-description, .ml-error .label-description p, .ml-error label:first-child { color: #c0392b !important; }
  @media only screen and (max-width: 580px) {
    .ml-form-embedWrapper.embedForm { width: 100% !important; }
  }
</style>

<div id="mlb2-41908249" class="ml-form-embedContainer ml-subscribe-form ml-subscribe-form-41908249">
  <div class="ml-form-align-center">
    <div class="ml-form-embedWrapper embedForm">

      <div class="ml-form-embedBody ml-form-embedBodyDefault row-form">

        <div class="ml-form-embedContent">
          <h4>Season 2 Registration</h4>
        </div>

        <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/2387578/forms/188742144996934769/subscribe" data-code="" method="post" target="_blank">
          <div class="ml-form-formContent">

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-name ml-validate-required">
                <label>Name*</label>
                <input aria-label="name" aria-required="true" type="text" class="form-control" name="fields[name]" placeholder="" autocomplete="given-name">
              </div>
            </div>

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-email ml-validate-email ml-validate-required">
                <label>Email*</label>
                <input aria-label="email" aria-required="true" type="email" class="form-control" name="fields[email]" placeholder="" autocomplete="email">
              </div>
            </div>

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-phone">
                <label>Best number to reach you 📱</label>
                <input aria-label="phone" type="text" class="form-control" name="fields[phone]" placeholder="" autocomplete="">
              </div>
            </div>

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-referral_source">
                <label>How did you hear about us?</label>
                <select class="custom-select" name="fields[referral_source]" aria-label="referral_source">
                  <option value="">-</option>
                  <option>A friend or fellow golfer</option>
                  <option>Facebook</option>
                  <option>Email invite</option>
                  <option>Other</option>
                </select>
              </div>
            </div>

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-returning_member">
                <label>Are you back for more, or brand new to the league?</label>
                <div class="custom-checkbox-radio-list">
                  <div class="custom-control custom-radio">
                    <input aria-label="returning_member" name="fields[returning_member]" class="custom-control-input" type="radio" value="I'm back from Season 1! 🎉" id="radio-41908249-43-0">
                    <label class="custom-control-label" for="radio-41908249-43-0">I'm back from Season 1! 🎉</label>
                  </div>
                  <div class="custom-control custom-radio">
                    <input aria-label="returning_member" name="fields[returning_member]" class="custom-control-input" type="radio" value="Brand new — first season!" id="radio-41908249-43-1">
                    <label class="custom-control-label" for="radio-41908249-43-1">Brand new — first season!</label>
                  </div>
                </div>
              </div>
            </div>

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-golf_level ml-validate-required">
                <label>How would you describe your golf game?</label>
                <div class="custom-checkbox-radio-list">
                  <div class="custom-control custom-radio">
                    <input aria-label="golf_level" aria-required="true" name="fields[golf_level]" class="custom-control-input" type="radio" value="New to golf or just getting started" id="radio-41908249-53-0">
                    <label class="custom-control-label" for="radio-41908249-53-0">New to golf or just getting started</label>
                  </div>
                  <div class="custom-control custom-radio">
                    <input aria-label="golf_level" aria-required="true" name="fields[golf_level]" class="custom-control-input" type="radio" value="Comfortable on the course" id="radio-41908249-53-1">
                    <label class="custom-control-label" for="radio-41908249-53-1">Comfortable on the course</label>
                  </div>
                </div>
              </div>
            </div>

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-season_cadence">
                <label>How are you picturing your season?</label>
                <div class="custom-checkbox-radio-list">
                  <div class="custom-control custom-radio">
                    <input aria-label="season_cadence" name="fields[season_cadence]" class="custom-control-input" type="radio" value="I want a regular Monday spot" id="radio-41908249-63-0">
                    <label class="custom-control-label" for="radio-41908249-63-0">I want a regular Monday spot</label>
                  </div>
                  <div class="custom-control custom-radio">
                    <input aria-label="season_cadence" name="fields[season_cadence]" class="custom-control-input" type="radio" value="I'll drop in when I can" id="radio-41908249-63-1">
                    <label class="custom-control-label" for="radio-41908249-63-1">I'll drop in when I can</label>
                  </div>
                  <div class="custom-control custom-radio">
                    <input aria-label="season_cadence" name="fields[season_cadence]" class="custom-control-input" type="radio" value="Honestly, not sure yet — and that's okay!" id="radio-41908249-63-2">
                    <label class="custom-control-label" for="radio-41908249-63-2">Honestly, not sure yet — and that's okay!</label>
                  </div>
                </div>
              </div>
            </div>

            <div class="ml-form-fieldRow">
              <div class="ml-field-group ml-field-additional_notes">
                <label>Anything else you would like us to know?</label>
                <textarea class="form-control" name="fields[additional_notes]" aria-label="additional_notes" maxlength="1024" placeholder=""></textarea>
              </div>
            </div>

            <div class="ml-form-fieldRow ml-last-item">
              <div class="ml-field-group ml-field-agreed_to_terms ml-validate-required">
                <label>Ladies on the Links is a recreational league, and details like tee times, fees, and scheduling will be confirmed after I register.</label>
                <div class="custom-checkbox-radio-list">
                  <div class="custom-control custom-checkbox">
                    <input name="fields[agreed_to_terms][]" aria-label="agreed_to_terms" aria-required="true" class="custom-control-input" type="checkbox" value="I Understand" id="checkbox-41908249-83-0">
                    <label class="custom-control-label" for="checkbox-41908249-83-0">I Understand</label>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <input type="hidden" name="ml-submit" value="1">

          <div class="ml-form-embedSubmit">
            <button type="submit" class="primary">Sign me up!</button>
            <button disabled="disabled" style="display: none;" type="button" class="loading">
              <div class="ml-form-embedSubmitLoad"></div>
              <span class="sr-only">Loading...</span>
            </button>
          </div>

          <input type="hidden" name="anticsrf" value="true">
        </form>
      </div>

      <div class="ml-form-successBody row-success" style="display: none">
        <div class="ml-form-successContent">
          <h4>You're in! ⛳</h4>
          <p style="text-align: center;">Welcome to Ladies on the Links, Season 2! Your spot is saved. Keep an eye on your inbox. Stacey will be in touch soon with schedule details, group info, and everything you need to know for the season.</p>
        </div>
      </div>

    </div>
  </div>
</div>

<script is:inline>
  function ml_webform_success_41908249() {
    var $ = window.ml_jQuery || window.jQuery;
    $('.ml-subscribe-form-41908249 .row-success').show();
    $('.ml-subscribe-form-41908249 .row-form').hide();
  }
</script>
