---
// Three feature cards (build inputs §4), each a jump-off into the site.
const cards = [
  {
    href: '/register',
    cta: 'Start here',
    title: 'All Skill Levels',
    body: 'Whether you just bought your first set of clubs or you have been playing for years, you belong here. No pressure, no judgment, just joy.',
  },
  {
    href: '/schedule',
    cta: 'See the schedule',
    title: 'Weekly Play & Lessons',
    body: 'Monday tee times all season, plus small-group lessons with our pro, Christian Grace. Nine holes, scramble format, cart included.',
  },
  {
    href: '/gallery',
    cta: 'Browse the gallery',
    title: 'A Real Community',
    body: 'Weekly contests, seasonal events like Glow Golf, a year-end tournament, and a great group of women who love a good Monday on the course.',
  },
];
---

<section class="mx-auto max-w-6xl px-6 py-8">
  <ul data-feature-cards class="grid gap-6 md:grid-cols-3">
    {cards.map((c, i) => (
      <li class:list={['', i === 1 && 'md:translate-y-6']}>
        <a
          href={c.href}
          class="group flex h-full flex-col rounded-[2rem] border border-forest/10 bg-cream-soft/70 p-7 shadow-[0_18px_50px_-30px_rgba(26,74,51,0.6)] backdrop-blur transition-all duration-300 hover:-translate-y-1.5 hover:border-forest/20 hover:shadow-[0_28px_60px_-28px_rgba(26,74,51,0.55)]"
        >
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-gradient-to-br from-forest to-rose text-cream-soft">
            <span class="font-serif text-lg">{i + 1}</span>
          </span>
          <h3 class="mt-5 font-serif text-2xl font-normal text-forest">{c.title}</h3>
          <p class="mt-3 flex-1 leading-relaxed text-slate">{c.body}</p>
          <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium tracking-wide text-rose">
            {c.cta}
            <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
          </span>
        </a>
      </li>
    ))}
  </ul>
</section>
