---
// Three feature cards (build inputs §4), each a jump-off into the site.
const cards = [
  {
    href: '/register',
    cta: 'Start here',
    title: 'All Skill Levels',
    body: 'Whether you just bought your first set of clubs or you have been playing for years, you belong here. No pressure, no judgment, just joy.',
  },
  {
    href: '/schedule',
    cta: 'See the schedule',
    title: 'Weekly Play & Lessons',
    body: 'Monday tee times all season, plus small-group lessons with our pro, Christian Grace. Nine holes, scramble format, cart included.',
  },
  {
    href: '/league-life',
    cta: 'See league life',
    title: 'A Real Community',
    body: 'Weekly contests, seasonal events like Glow Golf, a year-end tournament, and a great group of women who love a good Monday on the course.',
  },
];
---

<section class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
  <ul data-feature-cards class="border-t border-forest/15">
    {cards.map((c, i) => (
      <li class="border-b border-forest/15 reveal" style={`transition-delay:${i * 90}ms`}>
        <a
          href={c.href}
          class="group relative grid grid-cols-[auto_1fr] items-baseline gap-x-5 gap-y-3 px-2 py-9 transition-colors duration-300 hover:bg-cream-soft/70 sm:grid-cols-[5rem_1fr_auto] sm:gap-x-8 sm:py-12"
        >
          <span class="absolute inset-y-6 left-0 w-0.5 origin-top scale-y-0 bg-rose transition-transform duration-500 group-hover:scale-y-100" aria-hidden="true"></span>
          <span class="font-serif text-3xl font-light italic text-rose sm:text-4xl">0{i + 1}</span>
          <div class="col-start-2 sm:col-start-auto">
            <h3 class="font-serif text-3xl font-normal leading-tight text-forest sm:text-4xl">{c.title}</h3>
            <p class="mt-2 max-w-xl leading-relaxed text-slate">{c.body}</p>
            <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-rose sm:hidden">
              {c.cta}
              <span aria-hidden="true">&rarr;</span>
            </span>
          </div>
          <span class="col-start-2 hidden items-center gap-2 self-center whitespace-nowrap text-sm font-medium text-rose sm:col-start-auto sm:inline-flex">
            {c.cta}
            <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
          </span>
        </a>
      </li>
    ))}
  </ul>
</section>
