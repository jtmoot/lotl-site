---
// Playful four-stat bar (build inputs §4). Exact strings asserted by tests.
const stats = [
  '220+ ladies and counting',
  'Every Monday, June to September',
  'Countless memories made',
  '2 seasons strong',
];
---

<section class="mt-16 bg-gradient-to-b from-blush/20 to-cream">
  <div data-stats class="mx-auto grid max-w-6xl gap-8 px-6 py-16 text-center sm:grid-cols-2 lg:grid-cols-4">
    {stats.map((s) => {
      const [lead, ...rest] = s.split(' ');
      return (
        <div>
          <p class="bg-gradient-to-br from-rose to-forest bg-clip-text font-serif text-3xl font-light text-transparent sm:text-4xl">
            {lead}
          </p>
          <p class="mt-2 text-sm leading-snug tracking-wide text-slate">{rest.join(' ')}</p>
        </div>
      );
    })}
  </div>
</section>
