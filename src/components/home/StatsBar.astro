---
// Playful four-stat bar (build inputs §4). Exact strings asserted by tests.
const stats = [
  '220+ ladies and counting',
  'Every Monday, June to September',
  'Countless memories made',
  '2 seasons strong',
];
---

<section class="mx-auto max-w-6xl px-6 pb-8 pt-4">
  <div class="rule"></div>
  <div data-stats class="grid gap-y-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    {stats.map((s, i) => {
      const [lead, ...rest] = s.split(' ');
      return (
        <div
          class:list={['px-6 text-center lg:text-left reveal', i > 0 && 'lg:border-l lg:border-forest/12']}
          style={`transition-delay:${i * 80}ms`}
        >
          <p class="font-serif text-5xl font-light leading-none text-rose">{lead}</p>
          <p class="mt-3 text-[0.72rem] uppercase leading-relaxed tracking-[0.16em] text-slate">{rest.join(' ')}</p>
        </div>
      );
    })}
  </div>
  <div class="rule"></div>
</section>
