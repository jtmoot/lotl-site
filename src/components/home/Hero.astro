---
import { Image } from 'astro:assets';
import hero from '../../assets/photos/hero-course.jpg';
---

<section data-hero class="relative isolate flex min-h-[88svh] items-end overflow-hidden border-b border-forest/12">
  <Image
    src={hero}
    alt="The North Hill golf course at golden hour"
    width={2200}
    height={1400}
    class="hero-settle absolute inset-0 -z-10 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <!-- Dual scrim: left band for headline legibility, base fade to ground the photo. -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-forest-deep/90 via-forest-deep/45 to-transparent"></div>
  <div class="absolute inset-x-0 bottom-0 -z-10 h-2/3 bg-gradient-to-t from-forest-deep/85 to-transparent"></div>
  <div data-spotlight class="hero-spotlight pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>

  <div class="mx-auto w-full max-w-6xl px-6 pb-16 pt-32 sm:pb-20 lg:pb-24">
    <div class="max-w-3xl">
      <p class="eyebrow eyebrow-mark text-blush rise" style="animation-delay:80ms">For the love of golf</p>
      <h1
        class="mt-4 font-serif font-light leading-[0.95] tracking-[-0.02em] text-cream rise"
        style="font-size:clamp(2.9rem,8vw,6.75rem);animation-delay:160ms"
      >
        The league that <em class="italic text-blush">plays</em> together.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream/90 rise" style="animation-delay:260ms">
        A women's golf league at North Hill Country Club in Duxbury. Every Monday, all season long,
        all skill levels. Come sip, swing, and make some new friends.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3 rise" style="animation-delay:360ms">
        <a href="/register" class="hero-cta-light">Register for Season 2</a>
        <a href="/schedule" class="hero-cta-ghost">Book a Tee Time</a>
      </div>
      <p class="mt-10 flex items-center gap-3 text-sm tracking-wide text-cream/70 rise" style="animation-delay:460ms">
        <span class="h-px w-8 bg-cream/40"></span>
        North Hill Country Club, Duxbury MA
      </p>
    </div>
  </div>

  <div class="absolute bottom-10 right-10 hidden sm:block rise" style="animation-delay:700ms" aria-hidden="true">
    <span class="scroll-cue block h-14 w-px bg-cream/50"></span>
  </div>
</section>

<script>
  // Cursor spotlight: lerp a soft light toward the pointer (see .hero-spotlight
  // in global.css). Mouse-only and motion-gated; touch and reduced-motion
  // visitors keep the plain photograph.
  const hero = document.querySelector<HTMLElement>('[data-hero]');
  const spot = document.querySelector<HTMLElement>('[data-spotlight]');
  const finePointer = window.matchMedia('(pointer: fine)').matches;
  const motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && spot && finePointer && motionOk) {
    let targetX = 0.5, targetY = 0.4;
    let x = targetX, y = targetY;
    let raf = 0;

    const tick = () => {
      x += (targetX - x) * 0.08;
      y += (targetY - y) * 0.08;
      spot.style.setProperty('--spot-x', `${(x * 100).toFixed(2)}%`);
      spot.style.setProperty('--spot-y', `${(y * 100).toFixed(2)}%`);
      const settled = Math.abs(targetX - x) < 0.001 && Math.abs(targetY - y) < 0.001;
      raf = settled ? 0 : requestAnimationFrame(tick);
    };

    hero.addEventListener('pointermove', (e) => {
      const r = hero.getBoundingClientRect();
      targetX = (e.clientX - r.left) / r.width;
      targetY = (e.clientY - r.top) / r.height;
      spot.classList.add('is-lit');
      if (!raf) raf = requestAnimationFrame(tick);
    });
    hero.addEventListener('pointerleave', () => spot.classList.remove('is-lit'));
  }
</script>
