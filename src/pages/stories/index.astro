---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageIntro from '../../components/PageIntro.astro';

// The dated, indexed blog. Posts are schema-validated Markdown in the `stories`
// collection. Read-only by design: no comments, reactions, or on-site subscribe
// (subscribing lives with MailerLite). Newest first.
const posts = (await getCollection('stories', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Layout
  title="Stories · Ladies on the Links"
  description="Stories from the Links. Member spotlights, event recaps, and tips from our pro Christian Grace, from the Ladies on the Links women's golf league in Duxbury, MA."
>
  <PageIntro
    eyebrow="News & Recaps"
    title="Stories from the Links"
    lede="The women, the Mondays, the moments. Member spotlights, event recaps, and the occasional tip from our pro Christian Grace."
  />

  <section class="mx-auto max-w-5xl px-6 pb-24">
    {posts.length === 0 ? (
      <p class="text-center text-slate">More stories are on the way. 💚</p>
    ) : (
      <ul data-stories-list class="grid gap-8 sm:grid-cols-2">
        {posts.map((post, i) => (
          <li
            class:list={[
              'group overflow-hidden rounded-xl border border-forest/10 bg-cream-soft/60 reveal',
              'transition-shadow duration-300 hover:shadow-[0_24px_50px_-32px_rgba(26,74,51,0.45)]',
            ]}
            style={`transition-delay:${(i % 2) * 90}ms`}
          >
            <a href={`/stories/${post.id}`} class="block">
              <Image
                src={post.data.cover}
                alt={`Cover image for ${post.data.title}`}
                widths={[400, 800]}
                sizes="(min-width: 640px) 50vw, 100vw"
                class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                loading="lazy"
              />
              <div class="p-6">
                <p class="eyebrow">
                  {dateFmt.format(post.data.date)}
                  {post.data.attribution && <span> · Featuring {post.data.attribution}</span>}
                </p>
                <h2 class="mt-2 font-serif text-2xl font-light leading-snug text-forest">
                  {post.data.title}
                </h2>
                <p class="mt-3 text-sm text-slate">By {post.data.author}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
