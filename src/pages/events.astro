---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';

// Special events beyond weekly league play. Entries are schema-validated
// Markdown in the `events` collection; there are no detail pages, each body
// renders inline on its card. Grouped by status: upcoming (announced, big
// cards), teaser (dream stage, no booking CTA), past (renders only if any).
const all = await getCollection('events', ({ data }) => !data.draft);

const byDate = (a: (typeof all)[number], b: (typeof all)[number]) => {
  // Dated entries first (soonest first); undated ("Date coming soon") last.
  if (a.data.date && b.data.date) return a.data.date.valueOf() - b.data.date.valueOf();
  if (a.data.date) return -1;
  if (b.data.date) return 1;
  return a.data.title.localeCompare(b.data.title);
};

const upcoming = all.filter((e) => e.data.status === 'upcoming').sort(byDate);
const teasers = all.filter((e) => e.data.status === 'teaser').sort(byDate);
const past = all
  .filter((e) => e.data.status === 'past')
  .sort((a, b) => byDate(b, a));

const rendered = new Map<string, any>();
for (const event of [...upcoming, ...teasers, ...past]) {
  const { Content } = await render(event);
  rendered.set(event.id, Content);
}

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const dateLabel = (event: (typeof all)[number]) =>
  event.data.dateLabel ?? (event.data.date ? dateFmt.format(event.data.date) : 'Date coming soon');
---

<Layout
  title="Events · Ladies on the Links"
  description="Special events from the Ladies on the Links women's golf league in Duxbury, MA: Glo Golf, tournaments, winter pop ups, and what's on the horizon."
>
  <PageIntro
    eyebrow="Beyond Mondays"
    title="Events on the Links"
    lede="The special stuff: night golf, tournaments, winter pop ups, and a few dreams in the making. Booking always happens on the Schedule page."
  />

  {upcoming.length === 0 && teasers.length === 0 && past.length === 0 && (
    <section class="mx-auto max-w-5xl px-6 pb-24">
      <p class="text-center text-slate">More events are on the way. 💚</p>
    </section>
  )}

  {upcoming.length > 0 && (
    <section data-events="upcoming" class="mx-auto max-w-5xl px-6 pb-16">
      <h2 class="eyebrow eyebrow-mark reveal">Coming up</h2>
      <ul class="mt-6 grid gap-8">
        {upcoming.map((event, i) => {
          const Content = rendered.get(event.id);
          return (
            <li
              class="group overflow-hidden rounded-xl border border-forest/10 bg-cream-soft/60 reveal card-lift"
              style={`transition-delay:${(i % 2) * 90}ms`}
            >
              <div class="grid sm:grid-cols-[2fr_3fr]">
                {event.data.image && (
                  <Image
                    src={event.data.image}
                    alt={`${event.data.title} event poster`}
                    widths={[480, 960]}
                    sizes="(min-width: 640px) 40vw, 100vw"
                    class="h-full min-h-56 w-full object-cover"
                    loading="lazy"
                  />
                )}
                <div class="p-7 sm:p-9">
                  <p class="eyebrow">{dateLabel(event)}</p>
                  <h3 class="mt-2 font-serif text-3xl font-light leading-snug text-forest">
                    {event.data.title}
                  </h3>
                  <p class="mt-2 font-serif text-lg italic text-rose">{event.data.tagline}</p>
                  <div class="mt-4 space-y-3 leading-relaxed text-slate">
                    <Content />
                  </div>
                  {event.data.bookingUrl && (
                    <p class="mt-6">
                      <a href={event.data.bookingUrl} data-cta class="zen-btn px-6 py-2.5 text-sm">
                        Save your spot
                      </a>
                    </p>
                  )}
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {teasers.length > 0 && (
    <section data-events="teaser" class="mx-auto max-w-5xl px-6 pb-16">
      <h2 class="eyebrow eyebrow-mark reveal">On the horizon</h2>
      <ul class="mt-6 grid gap-8">
        {teasers.map((event) => {
          const Content = rendered.get(event.id);
          return (
            <li class="overflow-hidden rounded-xl border border-dashed border-forest/20 bg-blush/10 reveal">
              <div class:list={['grid', event.data.image && 'sm:grid-cols-[2fr_3fr]']}>
                {event.data.image && (
                  <Image
                    src={event.data.image}
                    alt={`${event.data.title} event poster`}
                    widths={[480, 960]}
                    sizes="(min-width: 640px) 40vw, 100vw"
                    class="h-full min-h-56 w-full object-cover"
                    loading="lazy"
                  />
                )}
                <div class="p-7 sm:p-9">
                  <p class="eyebrow">{dateLabel(event)}</p>
                  <h3 class="mt-2 font-serif text-3xl font-light leading-snug text-forest">
                    {event.data.title}
                  </h3>
                  <p class="mt-2 font-serif text-lg italic text-rose">{event.data.tagline}</p>
                  <div class="mt-4 max-w-2xl space-y-3 leading-relaxed text-slate">
                    <Content />
                  </div>
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {past.length > 0 && (
    <section data-events="past" class="mx-auto max-w-5xl px-6 pb-16">
      <h2 class="eyebrow eyebrow-mark reveal">Good times we already had</h2>
      <ul class="mt-6 grid gap-8 sm:grid-cols-2">
        {past.map((event) => {
          const Content = rendered.get(event.id);
          return (
            <li class="rounded-xl border border-forest/10 bg-cream-soft/60 p-7 reveal">
              <p class="eyebrow">{dateLabel(event)}</p>
              <h3 class="mt-2 font-serif text-2xl font-light leading-snug text-forest">
                {event.data.title}
              </h3>
              <div class="mt-3 space-y-3 text-sm leading-relaxed text-slate">
                <Content />
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <section class="mx-auto max-w-3xl px-6 pb-24">
    <div class="flex flex-col items-center gap-3 rounded-xl border border-forest/10 bg-blush/10 p-7 text-center reveal">
      <h2 class="font-serif text-2xl text-forest">Have an idea for an event?</h2>
      <p class="max-w-xl leading-relaxed text-slate">
        Indoor golf, a clinic you wish existed, a theme night. We are all ears.
      </p>
      <a href="/contact" class="ghost-btn">Tell us about it &rarr;</a>
    </div>
  </section>
</Layout>
