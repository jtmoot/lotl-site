---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';
---

<Layout
  title="Merch · Ladies on the Links"
  description="Ladies on the Links league gear is on the way. Hats, layers, and more, coming soon."
>
  <PageIntro eyebrow="The pro shop" title="Merch is on the way" />

  <section class="mx-auto max-w-2xl px-6 pb-28">
    <div class="relative overflow-hidden rounded-xl border border-forest/10 bg-gradient-to-br from-cream-soft to-blush/15 p-10 text-center shadow-[0_28px_70px_-44px_rgba(26,74,51,0.55)] sm:p-14 reveal">
      <span class="eyebrow eyebrow-mark">Coming soon</span>
      <h2 class="mt-4 font-serif text-3xl font-light text-forest sm:text-4xl">
        Ladies on the Links merch is on the way.
      </h2>
      <p class="mx-auto mt-5 max-w-md text-lg leading-relaxed text-slate">
        We are putting together gear so you can rep the league on and off the course.
        Hats, layers, and more, coming soon. Keep an eye out. 👀
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/register" class="zen-btn">Register for the season</a>
        <a href="/contact" class="ghost-btn">Ask us anything</a>
      </div>
    </div>
  </section>
</Layout>
