---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';

// Formspree endpoint (confirmed) -> shared league inbox. No backend.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mvznnvdv';

// Quick answers (formerly the /faq page; merged here in the 2026-07 nav
// consolidation, /faq redirects to this page). Drafted Q&A (build inputs §4),
// used verbatim, except the cancellation and weather answers, which follow
// Stacey's published policies (see /policies). An optional `link` renders a
// "Read the full policy" line after the answer.
const faqs = [
  {
    q: 'Who is this league for?',
    a: 'Every woman who wants to swing a club, sip a drink, and have fun on a Monday. All ages, all skill levels, all stages. Brand new to golf or been playing for years, you belong here.',
  },
  {
    q: 'How does it work?',
    a: 'Nine holes in a scramble format, which means you play as a team, so there is no pressure. Golf cart included. $45 per round, weekly contests, and a great group of women.',
  },
  {
    q: 'Where do we go?',
    a: 'North Hill Country Club, 29 Merry Avenue, Duxbury, MA. Look for the Ladies on the Links table on the porch facing the 9th hole, and try to arrive about 30 minutes early.',
  },
  {
    q: 'Where do I book?',
    a: 'Tee times and lessons are booked through the Schedule page right here on the site. Register first so you are on the email list.',
  },
  {
    q: 'When do tee times come out?',
    a: 'New tee times are released on the first Sunday of each month, a few weeks at a time. Keep an eye on your inbox so you do not miss the dates you want.',
  },
  {
    q: 'Can I cancel, and how?',
    a: 'You have 24 hours after booking to cancel through your Bookwhen confirmation email, and your spot goes to the waitlist automatically. After that you are locked in, and no-shows forfeit their spot. Need a different time instead? Bookwhen lets you transfer your booking to another open slot, once per booking. For anything urgent, text Stacey or email ladiesonthelinks.league@gmail.com. Please do not cancel through Facebook posts or DMs, those can be missed.',
    link: '/policies#cancellation',
  },
  {
    q: 'Can I see who is golfing?',
    a: 'Yes. The live tee sheet (linked on the Schedule page) shows who is signed up for each time.',
  },
  {
    q: 'What should I bring?',
    a: 'Your clubs (no rentals at the course, but we have loaner sets, just check the "Need to borrow clubs?" box when you book), golf balls, a glove, tees, water or a cooler, a layer for New England evenings, sunscreen, and a great attitude.',
  },
  {
    q: 'What does it cost?',
    a: '$45 per round and $35 per lesson. No membership dues.',
  },
  {
    q: 'What if it rains?',
    a: 'We play in the rain. Light or steady rain is not a cancellation, and league play is called off only when conditions are dangerous or the course closes. Our pro, Christian Grace, makes the final call with North Hill Country Club, and you will hear from us by league email and Facebook no later than 1 hour before your tee time. Clinics cancel more readily, and you will always be offered a makeup slot.',
    link: '/policies#weather',
  },
];
---

<Layout
  title="Contact & FAQ · Ladies on the Links"
  description="Answers to common questions about the Ladies on the Links women's golf league in Duxbury, MA, and a quick way to send us a note. We'd love to hear from you."
>
  <PageIntro
    eyebrow="Say hello"
    title="Questions? Get in touch."
    lede="Quick answers to the things everyone asks are below. Anything else, send us a note and we'll get back to you."
  />

  <!-- Quick answers (formerly /faq) -->
  <section id="faq" class="mx-auto max-w-3xl scroll-mt-24 px-6 pb-16">
    <h2 class="eyebrow eyebrow-mark reveal">Quick answers</h2>
    <ul class="mt-6 divide-y divide-forest/10 overflow-hidden rounded-xl border border-forest/10 bg-cream-soft/60 reveal">
      {faqs.map((f) => (
        <li>
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left font-serif text-lg text-forest transition-colors hover:bg-forest/5">
              <span>{f.q}</span>
              <span class="shrink-0 text-rose transition-transform duration-300 group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <div class="px-6 pb-6 leading-relaxed text-slate">
              <p>{f.a}</p>
              {f.link && (
                <p class="mt-2 text-sm">
                  <a href={f.link} class="font-medium text-rose underline-offset-4 hover:underline">Read the full policy &rarr;</a>
                </p>
              )}
            </div>
          </details>
        </li>
      ))}
    </ul>
  </section>

  <!-- Diamond divider (accent motif shared with Home). -->
  <div class="mx-auto flex max-w-xs items-center gap-4 px-6 pb-16" aria-hidden="true">
    <span class="rule flex-1"></span>
    <span class="h-1.5 w-1.5 rotate-45 bg-rose"></span>
    <span class="rule flex-1"></span>
  </div>

  <!-- Send a note -->
  <section id="message" class="mx-auto max-w-xl scroll-mt-24 px-6 pb-24">
    <h2 class="eyebrow eyebrow-mark mb-6 reveal">Send us a note</h2>
    <form
      id="contact-form"
      action={FORMSPREE_ENDPOINT}
      method="POST"
      class="rounded-xl border border-forest/10 bg-cream-soft/60 p-7 shadow-[0_24px_60px_-36px_rgba(26,74,51,0.5)] sm:p-8 reveal"
    >
      <div class="space-y-5">
        <div>
          <label for="cf-name" class="mb-1.5 block text-sm font-medium text-forest">Name</label>
          <input id="cf-name" name="name" type="text" required autocomplete="name"
            class="w-full rounded-xl border border-forest/25 bg-white px-3.5 py-2.5 text-ink outline-none transition focus:border-rose focus:ring-2 focus:ring-rose/20" />
        </div>
        <div>
          <label for="cf-email" class="mb-1.5 block text-sm font-medium text-forest">Email</label>
          <input id="cf-email" name="email" type="email" required autocomplete="email"
            class="w-full rounded-xl border border-forest/25 bg-white px-3.5 py-2.5 text-ink outline-none transition focus:border-rose focus:ring-2 focus:ring-rose/20" />
        </div>
        <div>
          <label for="cf-message" class="mb-1.5 block text-sm font-medium text-forest">Message</label>
          <textarea id="cf-message" name="message" rows="5" required
            class="w-full rounded-xl border border-forest/25 bg-white px-3.5 py-2.5 text-ink outline-none transition focus:border-rose focus:ring-2 focus:ring-rose/20"></textarea>
        </div>
      </div>

      <button type="submit"
        class="zen-btn mt-6 w-full justify-center" data-submit>
        Send message
      </button>

      <p data-form-success hidden role="status"
        class="mt-4 rounded-xl bg-forest/10 px-4 py-3 text-center text-sm text-forest">
        Thank you! Your message is on its way. We'll be in touch soon. 💚
      </p>
      <p data-form-error hidden role="alert"
        class="mt-4 rounded-xl bg-rose/15 px-4 py-3 text-center text-sm text-rose">
        Something went wrong sending your message. Please try again, or email stacey@ladiesonthelinksgolf.com.
      </p>
    </form>
  </section>
</Layout>

<script is:inline>
  (() => {
    const form = document.getElementById('contact-form');
    if (!form) return;
    const success = form.querySelector('[data-form-success]');
    const error = form.querySelector('[data-form-error]');
    const button = form.querySelector('[data-submit]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      success.setAttribute('hidden', '');
      error.setAttribute('hidden', '');
      button.setAttribute('disabled', '');
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          success.removeAttribute('hidden');
        } else {
          error.removeAttribute('hidden');
        }
      } catch {
        error.removeAttribute('hidden');
      } finally {
        button.removeAttribute('disabled');
      }
    });
  })();
</script>
