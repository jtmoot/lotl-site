---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';

// League Life: the merged Stories + Gallery page (nav consolidation, 2026-07).
// Stories up top (dated, indexed blog cards; posts still live at
// /stories/<slug>), anonymous photo wall below. Old /stories and /gallery
// URLs redirect here via astro.config redirects. Read-only by design: no
// comments, reactions, or on-site subscribe (subscribing lives with MailerLite).
const posts = (await getCollection('stories', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

// Anonymous photo grid (not a feed). Entries are curated Markdown files in the
// `gallery` collection; no member names or per-photo captions at launch.
const entries = await getCollection('gallery', ({ data }) => !data.draft);

// A generic, never-personal fallback so every tile keeps accessible alt text.
const FALLBACK_ALT = 'North Hill Country Club course';

const tiles = entries.flatMap((entry) =>
  entry.data.images.map((image) => ({
    image,
    alt: entry.data.alt ?? FALLBACK_ALT,
  }))
);
---

<Layout
  title="League Life · Ladies on the Links"
  description="Stories and photos from the Ladies on the Links women's golf league in Duxbury, MA. Member spotlights, event recaps, tips from our pro Christian Grace, and scenes from our Mondays at North Hill."
>
  <PageIntro
    eyebrow="News, recaps & photos"
    title="League Life"
    lede="The women, the Mondays, the moments. Member spotlights, event recaps, the occasional tip from our pro Christian Grace, and scenes from the course."
  />

  <!-- Stories -->
  <section class="mx-auto max-w-5xl px-6 pb-16">
    <h2 class="eyebrow eyebrow-mark reveal">Stories from the Links</h2>
    {posts.length === 0 ? (
      <p class="mt-6 text-center text-slate">More stories are on the way. 💚</p>
    ) : (
      <ul data-stories-list class="mt-6 grid gap-8 sm:grid-cols-2">
        {posts.map((post, i) => (
          <li
            class:list={[
              'group overflow-hidden rounded-xl border border-forest/10 bg-cream-soft/60 reveal card-lift',
            ]}
            style={`transition-delay:${(i % 2) * 90}ms`}
          >
            <a href={`/stories/${post.id}`} class="block">
              <Image
                src={post.data.cover}
                alt={`Cover image for ${post.data.title}`}
                widths={[400, 800]}
                sizes="(min-width: 640px) 50vw, 100vw"
                class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                loading="lazy"
              />
              <div class="p-6">
                <p class="eyebrow">
                  {dateFmt.format(post.data.date)}
                  {post.data.attribution && <span> · Featuring {post.data.attribution}</span>}
                </p>
                <h3 class="mt-2 font-serif text-2xl font-light leading-snug text-forest">
                  {post.data.title}
                </h3>
                <p class="mt-3 text-sm text-slate">By {post.data.author}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- Diamond divider (accent motif shared with Home). -->
  <div class="mx-auto flex max-w-xs items-center gap-4 px-6 pb-16" aria-hidden="true">
    <span class="rule flex-1"></span>
    <span class="h-1.5 w-1.5 rotate-45 bg-rose"></span>
    <span class="rule flex-1"></span>
  </div>

  <!-- Photos -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <h2 class="eyebrow eyebrow-mark reveal">On the course</h2>
    <p class="mt-3 max-w-2xl text-slate reveal">
      A curated look at the course and the league. Want a photo of yours added or removed?
      <a href="/contact" class="font-medium text-rose underline-offset-4 hover:underline">Get in touch</a>.
    </p>
    {tiles.length === 0 ? (
      <p class="mt-6 text-center text-slate">Photos coming soon.</p>
    ) : (
      <!-- Staggered wall: on md+, the middle column drops for an editorial rhythm. -->
      <ul data-gallery-grid class="mt-8 grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 md:pb-8">
        {tiles.map((tile, i) => (
          <li
            class:list={[
              'aspect-[4/5] overflow-hidden rounded-lg border border-forest/10 bg-cream-soft/60 reveal',
              i % 3 === 1 && 'md:translate-y-8',
            ]}
            style={`transition-delay:${(i % 3) * 70}ms`}
          >
            <Image
              src={tile.image}
              alt={tile.alt}
              widths={[400, 800, 1200]}
              sizes="(min-width: 768px) 33vw, 50vw"
              class="h-full w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
              loading="lazy"
            />
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
