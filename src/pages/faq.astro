---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';

// Drafted Q&A (build inputs §4), used verbatim. The weather answer is
// provisional (confirm with Stacey) and flagged as such.
const faqs = [
  {
    q: 'Who is this league for?',
    a: 'Every woman who wants to swing a club, sip a drink, and have fun on a Monday. All ages, all skill levels, all stages. Brand new to golf or been playing for years, you belong here.',
  },
  {
    q: 'How does it work?',
    a: 'Nine holes in a scramble format, which means you play as a team, so there is no pressure. Golf cart included. $45 per round, weekly contests, and a great group of women.',
  },
  {
    q: 'Where do we go?',
    a: 'North Hill Country Club, 29 Merry Avenue, Duxbury, MA. Look for the Ladies on the Links table on the porch facing the 9th hole, and try to arrive about 30 minutes early.',
  },
  {
    q: 'Where do I book?',
    a: 'Tee times and lessons are booked through the Schedule page right here on the site. Register first so you are on the email list.',
  },
  {
    q: 'When do tee times come out?',
    a: 'New tee times are released on the first Sunday of each month, a few weeks at a time. Keep an eye on your inbox so you do not miss the dates you want.',
  },
  {
    q: 'Can I cancel, and how?',
    a: 'Yes. Cancel up to 24 hours before your tee time through your booking link, and your spot goes to the waitlist automatically. Within 24 hours, text or email Stacey. All sales are final, but life happens and we handle true emergencies case by case.',
  },
  {
    q: 'Can I see who is golfing?',
    a: 'Yes. The live tee sheet (linked on the Schedule page) shows who is signed up for each time.',
  },
  {
    q: 'What should I bring?',
    a: 'Your clubs (no rentals at the course, but we have loaner sets, just check the "Need to borrow clubs?" box when you book), golf balls, a glove, tees, water or a cooler, a layer for New England evenings, sunscreen, and a great attitude.',
  },
  {
    q: 'What does it cost?',
    a: '$45 per round and $35 per lesson. No membership dues.',
  },
  {
    q: 'What if it rains?',
    a: 'Golf is a rain-or-shine sport, and we play through light weather. If conditions are truly unsafe (thunder, lightning, heavy storms), Stacey will email the group as early as possible to cancel or move that Monday. When in doubt, check your inbox before heading to the course. Weather cancellations called by the league are handled case by case.',
    provisional: true,
  },
];
---

<Layout
  title="FAQ · Ladies on the Links"
  description="Answers to common questions about the Ladies on the Links women's golf league in Duxbury, MA: how it works, costs, booking, and what to bring."
>
  <PageIntro
    eyebrow="Good to know"
    title="Frequently asked questions"
    lede="Everything you might be wondering before your first Monday. Still have a question? Reach out on the Contact page."
  />

  <section class="mx-auto max-w-3xl px-6 pb-24">
    <ul class="divide-y divide-forest/10 overflow-hidden rounded-[2rem] border border-forest/10 bg-cream-soft/60">
      {faqs.map((f) => (
        <li>
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left font-serif text-lg text-forest transition-colors hover:bg-forest/5">
              <span>{f.q}</span>
              <span class="shrink-0 text-rose transition-transform duration-300 group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <div class="px-6 pb-6 leading-relaxed text-slate">
              <p>{f.a}</p>
              {f.provisional && (
                <p class="mt-2 text-xs italic text-rose/80">This policy is being finalized; check your email for the latest.</p>
              )}
            </div>
          </details>
        </li>
      ))}
    </ul>
  </section>
</Layout>
