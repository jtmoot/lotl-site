{
  "name": "lotl-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test:schema": "node --test \"tests/schema/*.test.ts\"",
    "test:worker": "node --test \"tests/worker/*.test.ts\"",
