  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/postcss": "^4.3.1",
    "astro": "^6.4.8",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260704.1",
    "@playwright/test": "^1.61.0"
  }
}
